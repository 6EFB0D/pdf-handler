<Window x:Class="PdfHandler.UI.Views.UpdateAvailableNotificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="アップデートのお知らせ"
        Height="360"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="MessageTextBlock"
                   Grid.Row="0"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Foreground="#333333"
                   Margin="0,0,0,12"/>

        <CheckBox x:Name="SuppressCheckBox"
                  Grid.Row="1"
                  Content="このバージョンのお知らせを次回以降表示しない"
                  Margin="0,0,0,16"
                  FontSize="12"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="リリースページを開く"
                    Width="140"
                    Margin="0,0,8,0"
                    Padding="12,6"
                    IsDefault="True"
                    Click="OpenRelease_Click"/>
            <Button Content="あとで"
                    Width="90"
                    Padding="12,6"
                    IsCancel="True"
                    Click="Later_Click"/>
        </StackPanel>
    </Grid>
</Window>
