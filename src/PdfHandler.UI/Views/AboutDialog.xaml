<Window x:Class="PdfHandler.UI.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="バージョン情報"
        Height="420"
        Width="480"
        Icon="/Assets/PdfHandler.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- アイコン＋アプリ名 -->
            <RowDefinition Height="Auto"/>  <!-- バージョン・更新状態 -->
            <RowDefinition Height="Auto"/>  <!-- 説明 -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- 区切り -->
            <RowDefinition Height="Auto"/>  <!-- サポート 2ボタン -->
            <RowDefinition Height="Auto"/>  <!-- 区切り -->
            <RowDefinition Height="Auto"/>  <!-- 著作権 -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- フッターボタン -->
        </Grid.RowDefinitions>

        <!-- アイコン＋アプリ名 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
            <Image Source="/Assets/PdfHandler.ico" Width="44" Height="44"
                   VerticalAlignment="Center" Margin="0,0,10,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="PDFハンドラ" FontSize="28" FontWeight="Bold"
                       VerticalAlignment="Center" Foreground="#333333"/>
        </StackPanel>

        <!-- バージョン・更新状態 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,4">
            <TextBlock x:Name="VersionTextBlock" Text="バージョン 1.1.0"
                       FontSize="15" HorizontalAlignment="Center" Foreground="#555555"/>
            <TextBlock x:Name="EnvironmentTextBlock"
                       Visibility="Collapsed"
                       FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"
                       Foreground="#B45309" FontWeight="SemiBold"/>
            <TextBlock x:Name="UpdateStatusTextBlock" Text="🔄 更新を確認中..."
                       FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"
                       Foreground="#6C757D"/>
            <Button x:Name="UpdateButton" Content="🆕 今すぐアップデート"
                    Visibility="Collapsed" Click="UpdateButton_Click"
                    Margin="0,6,0,0" Padding="16,5" FontSize="12"
                    Background="#007BFF" Foreground="White" BorderThickness="0"
                    HorizontalAlignment="Center" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0056B3"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- 説明 -->
        <TextBlock Grid.Row="2" Text="ファイルサーバー上のPDFファイルを効率的に管理・編集するアプリケーション"
                   FontSize="12" HorizontalAlignment="Center" Foreground="#777777"
                   TextWrapping="Wrap" TextAlignment="Center"/>

        <!-- 区切り -->
        <Separator Grid.Row="4" Margin="0,0,0,10" Background="#DDDDDD"/>

        <!-- お問い合わせボタン -->
        <Button Grid.Row="5" Content="📋 お問い合わせフォーム"
                Click="SurveyForm_Click" Padding="10,8" Margin="0,0,0,10"
                Background="White" BorderBrush="#CCCCCC" Cursor="Hand" FontSize="12"
                HorizontalAlignment="Center" MinWidth="200"/>

        <!-- 区切り -->
        <Separator Grid.Row="6" Margin="0,0,0,8" Background="#DDDDDD"/>

        <!-- 著作権 -->
        <TextBlock Grid.Row="7" x:Name="CopyrightTextBlock"
                   Text="© 2025-2026 Office Go Plan. All rights reserved."
                   FontSize="11" HorizontalAlignment="Center" Foreground="#AAAAAA"/>

        <!-- フッターボタン -->
        <Grid Grid.Row="9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="更新を確認" Click="CheckUpdate_Click"
                    Padding="8,8" Background="White" BorderBrush="#CCCCCC" FontSize="12"/>
            <Button Grid.Column="2" Content="取扱説明書" Click="UserManual_Click"
                    Padding="8,8" Background="White" BorderBrush="#CCCCCC" FontSize="12"/>
            <Button Grid.Column="4" Content="ライセンス" Click="License_Click"
                    Padding="8,8" Background="White" BorderBrush="#CCCCCC" FontSize="12"/>
            <Button Grid.Column="6" Content="閉じる" Click="CloseButton_Click"
                    Padding="8,8" Background="#6C757D" Foreground="White"
                    BorderThickness="0" FontSize="12"/>
        </Grid>
    </Grid>
</Window>
