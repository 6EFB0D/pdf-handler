<Window x:Class="PdfHandler.UI.Views.LegalDocumentViewer"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="法的文書" 

        Height="650" 

        Width="850"

        WindowStartupLocation="CenterOwner"

        Background="#F5F5F5">

    <Grid Margin="25">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        

        <!-- タイトル -->

        <Border Grid.Row="0" 

                Background="White"

                BorderBrush="#DDDDDD"

                BorderThickness="0,0,0,1"

                Padding="0,0,0,15"

                Margin="0,0,0,15">

            <TextBlock x:Name="TitleTextBlock"

                       Text="文書"

                       FontSize="24"

                       FontWeight="Bold"

                       Foreground="#333333"/>

        </Border>

        

        <!-- 目次 + 本文 -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>

                <ColumnDefinition x:Name="TocColumn" Width="0"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>



            <Border x:Name="TocPanelBorder"

                    Grid.Column="0"

                    Visibility="Collapsed"

                    Background="White"

                    BorderBrush="#CCCCCC"

                    BorderThickness="1"

                    CornerRadius="5"

                    Margin="0,0,10,0"

                    Padding="8">

                <DockPanel LastChildFill="True">

                    <Button x:Name="TocHeaderButton"

                            DockPanel.Dock="Top"

                            Content="目次"

                            Click="TocHeader_Click"

                            FontWeight="Bold"

                            FontSize="14"

                            Margin="4,4,4,8"

                            Padding="4,2"

                            HorizontalAlignment="Left"

                            HorizontalContentAlignment="Left"

                            Background="Transparent"

                            BorderThickness="0"

                            Foreground="#0066CC"

                            Cursor="Hand"/>

                    <ListBox x:Name="ChapterListBox"

                             BorderThickness="0"

                             Background="Transparent"

                             FontFamily="Meiryo UI, Yu Gothic UI"

                             FontSize="12"

                             SelectionChanged="ChapterListBox_SelectionChanged"/>

                </DockPanel>

            </Border>



            <Border Grid.Column="1" 

                    Background="White"

                    BorderBrush="#CCCCCC"

                    BorderThickness="1"

                    CornerRadius="5">

                <ScrollViewer x:Name="ContentScrollViewer"

                              VerticalScrollBarVisibility="Auto"

                              Padding="20"

                              Focusable="True">

                    <RichTextBox x:Name="ContentRichTextBox"

                                 IsReadOnly="True"

                                 IsDocumentEnabled="True"

                                 BorderThickness="0"

                                 Background="Transparent"

                                 VerticalScrollBarVisibility="Disabled"

                                 HorizontalScrollBarVisibility="Disabled"

                                 FontFamily="Meiryo UI, Yu Gothic UI"

                                 FontSize="13"

                                 Foreground="#333333"/>

                </ScrollViewer>

            </Border>

        </Grid>

        

        <!-- ボタン -->

        <StackPanel Grid.Row="2" 

                    Orientation="Horizontal" 

                    HorizontalAlignment="Right"

                    Margin="0,20,0,0">

            <Button Content="📋 コピー" 

                    Click="Copy_Click"

                    Padding="15,10"

                    Margin="0,0,10,0"

                    Background="White"

                    BorderBrush="#CCCCCC"

                    Cursor="Hand"/>

            <Button Content="💾 保存" 

                    Click="Save_Click"

                    Padding="15,10"

                    Margin="0,0,10,0"

                    Background="White"

                    BorderBrush="#CCCCCC"

                    Cursor="Hand"/>

            <Button Content="🖨️ 印刷" 

                    Click="Print_Click"

                    Padding="15,10"

                    Margin="0,0,10,0"

                    Background="White"

                    BorderBrush="#CCCCCC"

                    Cursor="Hand"/>

            <Button Content="閉じる" 

                    Click="Close_Click"

                    Padding="15,10"

                    Background="#6C757D"

                    Foreground="White"

                    BorderThickness="0"

                    Cursor="Hand"/>

        </StackPanel>

    </Grid>

</Window>

