<Window x:Class="PdfHandler.UI.Views.LicenseKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ライセンスキー入力" 
        Height="250" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ライセンスキーを入力してください" 
                   FontSize="16" Margin="0,0,0,15"/>

        <TextBox x:Name="LicenseKeyTextBox" Grid.Row="1" 
                 Height="30" Margin="0,0,0,15"
                 TextWrapping="Wrap"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="ライセンスキーは購入時にメールでお送りします。" 
                       FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
            <TextBlock FontSize="12" Foreground="#666666">
                <Hyperlink x:Name="ForgotLicenseKeyLink" 
                           RequestNavigate="ForgotLicenseKey_RequestNavigate"
                           Foreground="#0066CC">
                    ライセンスキーを忘れた方はこちら
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="100" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="アクティベート" Width="100"
                    Click="Activate_Click"/>
        </StackPanel>
    </Grid>
</Window>






