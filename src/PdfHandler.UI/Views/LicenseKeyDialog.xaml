<Window x:Class="PdfHandler.UI.Views.LicenseKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ライセンスキー入力" 
        Height="230" 
        Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ライセンスキーを入力してください" 
                   FontSize="16" Margin="0,0,0,15"/>

        <TextBox x:Name="LicenseKeyTextBox" Grid.Row="1" 
                 Height="32" Margin="0,0,0,15"
                 FontFamily="Consolas"
                 FontSize="13"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Disabled"
                 HorizontalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="ライセンスキーは購入時にメールでお送りします。" 
                       FontSize="12" Foreground="#666666"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="100" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="アクティベート" Width="100"
                    Click="Activate_Click"/>
        </StackPanel>
    </Grid>
</Window>






