<Window x:Class="PdfHandler.UI.Views.BinderManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDFバインダー管理" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="PDFバインダー管理" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>
            <TextBlock Text="複数のPDFファイルを束ねて管理できます。" 
                       FontSize="13"
                       Foreground="#666666"/>
        </StackPanel>

        <!-- バインダー一覧 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 左側: バインダーリスト -->
            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ツールバー -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <Button Content="新規作成" Padding="10,5" Margin="0,0,5,0"
                                Click="CreateBinder_Click"/>
                        <Button Content="削除" Padding="10,5" Margin="0,0,5,0"
                                Click="DeleteBinder_Click"/>
                        <Button Content="結合" Padding="10,5"
                                Click="MergeBinder_Click"/>
                    </StackPanel>

                    <!-- バインダーリスト -->
                    <ListBox x:Name="BinderListBox" Grid.Row="1" 
                            SelectionChanged="BinderListBox_SelectionChanged"
                            Margin="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding PdfFilePaths.Count, StringFormat='{}{0}個のPDFファイル'}" 
                                              FontSize="11" Foreground="#666666" Margin="0,3,0,0"/>
                                    <TextBlock Text="{Binding UpdatedDate, StringFormat='更新: {0:yyyy/MM/dd HH:mm}'}" 
                                              FontSize="10" Foreground="#999999" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <!-- 右側: バインダー詳細 -->
            <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- バインダー情報 -->
                    <StackPanel Grid.Row="0" Margin="10">
                        <TextBlock x:Name="BinderNameTextBlock" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock x:Name="BinderDescriptionTextBlock" FontSize="12" Foreground="#666666" Margin="0,0,0,10"/>
                        <Button Content="PDFファイルを追加" Padding="10,5" Click="AddPdfToBinder_Click"/>
                    </StackPanel>

                    <!-- PDFファイル一覧 -->
                    <ListBox x:Name="PdfFileListBox" Grid.Row="1" Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="3">
                                    <TextBlock Text="📄" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- フッター -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="閉じる" Width="100" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>






