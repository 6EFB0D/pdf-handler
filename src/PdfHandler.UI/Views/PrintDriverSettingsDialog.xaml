<Window x:Class="PdfHandler.UI.Views.PrintDriverSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プリンタドライバ設定" 
        Height="300" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="プリンタドライバ設定" 
                       FontSize="18" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>
            <TextBlock Text="PDFファイルを印刷すると、専用ワークフォルダにPDFとして保存されます。" 
                       FontSize="13"
                       Foreground="#666666"/>
        </StackPanel>

        <!-- 設定項目 -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="ファイル名パターン" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <RadioButton x:Name="OriginalFileNameRadio" 
                        Content="元のファイル名を使用"
                        Margin="0,0,0,10"
                        IsChecked="True"/>
            
            <RadioButton x:Name="TimestampRadio" 
                        Content="タイムスタンプ形式（YYYYMMDD_HHMMSS.pdf）"
                        Margin="0,0,0,20"/>

            <TextBlock Text="ワークフォルダ" FontWeight="Bold" Margin="0,0,0,10"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="WorkFolderTextBox" Grid.Column="0" 
                        IsReadOnly="True"
                        Margin="0,0,5,0"/>
                <Button Content="参照..." Grid.Column="1" 
                       Click="BrowseWorkFolder_Click"
                       Padding="10,5"/>
            </Grid>
        </StackPanel>

        <!-- フッター -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="キャンセル" Width="100" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="OK" Width="100"
                    Click="OK_Click"/>
        </StackPanel>
    </Grid>
</Window>






