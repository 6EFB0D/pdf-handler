<Window x:Class="PdfHandler.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PDFハンドラ" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing">
    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{Binding RedoCommand}"/>
    </Window.InputBindings>
    
    <Window.Resources>
        <!-- ボタンスタイル -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="フォルダを開く(_O)..." Command="{Binding OpenFolderCommand}"/>
                <MenuItem Header="更新(_R)" Command="{Binding RefreshCommand}"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="編集(_E)">
                <MenuItem Header="元に戻す(_U)" Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="やり直し(_R)" Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="削除(_D)" Click="DeleteFiles_Click" InputGestureText="Delete"/>
                <Separator/>
                <MenuItem Header="すべて選択(_A)" InputGestureText="Ctrl+A"/>
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="サムネイルビュー(_T)" Command="{Binding ToggleViewCommand}" 
                          IsChecked="{Binding IsThumbnailView}"/>
                <MenuItem Header="リストビュー(_L)" Command="{Binding ToggleViewCommand}"
                          IsChecked="{Binding IsThumbnailView, Converter={StaticResource InverseBoolConverter}}"/>
                <Separator/>
                <MenuItem Header="サムネイルサイズ(_Z)">
                    <MenuItem Header="小(_S)" Command="{Binding SetThumbnailSizeCommand}" CommandParameter="Small"
                              IsChecked="{Binding IsSmallThumbnail}"/>
                    <MenuItem Header="中(_M)" Command="{Binding SetThumbnailSizeCommand}" CommandParameter="Medium"
                              IsChecked="{Binding IsMediumThumbnail}"/>
                    <MenuItem Header="大(_L)" Command="{Binding SetThumbnailSizeCommand}" CommandParameter="Large"
                              IsChecked="{Binding IsLargeThumbnail}"/>
                    <MenuItem Header="特大(_X)" Command="{Binding SetThumbnailSizeCommand}" CommandParameter="ExtraLarge"
                              IsChecked="{Binding IsExtraLargeThumbnail}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="プレビュー表示(_P)" Command="{Binding TogglePreviewCommand}"
                          IsChecked="{Binding IsPreviewVisible}"/>
            </MenuItem>
            <MenuItem Header="ツール(_T)">
                <MenuItem Header="PDFを結合(_M)..." Click="MergePdfs_Click" InputGestureText="Ctrl+M"/>
                <MenuItem Header="PDFを分割(_S)..." Command="{Binding SplitPdfCommand}"/>
                <MenuItem Header="ページの削除・挿入(_D)..." Command="{Binding PageOperationsCommand}"/>
                <MenuItem Header="ヘッダ・フッター(_H)..." Click="HeaderFooter_Click"/>
                <Separator/>
                <MenuItem Header="PDFを回転(_R)">
                    <MenuItem Header="現在のページを右に90度回転（時計回り）" Command="{Binding RotatePdfCommand}" CommandParameter="90"/>
                    <MenuItem Header="現在のページを左に90度回転（反時計回り）" Command="{Binding RotatePdfCommand}" CommandParameter="270"/>
                    <MenuItem Header="現在のページを180度回転" Command="{Binding RotatePdfCommand}" CommandParameter="180"/>
                </MenuItem>
                <MenuItem Header="全ページを回転(_A)">
                    <MenuItem Header="全ページを右に90度回転（時計回り）" Command="{Binding RotateAllPagesCommand}" CommandParameter="90"/>
                    <MenuItem Header="全ページを左に90度回転（反時計回り）" Command="{Binding RotateAllPagesCommand}" CommandParameter="270"/>
                    <MenuItem Header="全ページを180度回転" Command="{Binding RotateAllPagesCommand}" CommandParameter="180"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="PDFバインダー(_B)..." Click="OpenBinderManager_Click"/>
                <MenuItem Header="プリンタドライバ設定(_P)..." Click="PrintDriverSettings_Click"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="取扱説明書(_M)" Click="ShowUserManual_Click" InputGestureText="F1"/>
                <Separator/>
                <MenuItem x:Name="LicenseMenuItem" Header="ライセンス(_L)..." Click="License_Click"/>
                <MenuItem Header="バージョン情報(_A)" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- ツールバー -->
        <ToolBar Grid.Row="1" Height="40">
            <Button Content="↩ 元に戻す" Command="{Binding UndoCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="元に戻す (Ctrl+Z)"/>
            <Button Content="↪ やり直し" Command="{Binding RedoCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="やり直し (Ctrl+Y)"/>
            <Separator/>
            <Button Content="🔄 更新" Command="{Binding RefreshCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="ファイル一覧を更新"/>
            <Button Content="📁 開く" Command="{Binding OpenFolderCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="フォルダを開く"/>
            <Button Content="🗑️ 削除" Click="DeleteFiles_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="選択したファイルを削除（複数選択可）"/>
            <Separator/>
            <Button Content="🔗 結合" Click="MergePdfs_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="複数のPDFを結合（Ctrl+クリックで複数選択）"/>
            <Button Content="✂️ 分割" Command="{Binding SplitPdfCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="PDFを分割"/>
            <Button Content="📄 ページ編集" Command="{Binding PageOperationsCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="ページの削除・挿入"/>
            <Button Content="📋 ヘッダ・フッター" Click="HeaderFooter_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="ヘッダ・フッターの挿入"/>
            <Separator/>
            <!-- 右回転ボタン（時計回り） -->
            <Button Command="{Binding RotateAllPagesCommand}" CommandParameter="90" Style="{StaticResource ToolbarButtonStyle}" ToolTip="選択したPDFの全ページを右に90度回転">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="20" Height="20" Margin="0,0,4,0">
                        <Canvas Width="20" Height="20">
                            <!-- 時計回りの曲線矢印 -->
                            <Path Data="M 2,10 Q 10,2 18,10" 
                                  Stroke="Black" 
                                  StrokeThickness="2.5" 
                                  StrokeStartLineCap="Round" 
                                  StrokeEndLineCap="Round"/>
                            <!-- 矢印の先端 -->
                            <Path Data="M 15,7 L 18,10 L 15,13" 
                                  Stroke="Black" 
                                  StrokeThickness="2.5" 
                                  StrokeStartLineCap="Round" 
                                  StrokeEndLineCap="Round" 
                                  StrokeLineJoin="Round" 
                                  Fill="Black"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="90° 右回転" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </Button>
            <!-- 左回転ボタン（反時計回り） -->
            <Button Command="{Binding RotateAllPagesCommand}" CommandParameter="270" Style="{StaticResource ToolbarButtonStyle}" ToolTip="選択したPDFの全ページを左に90度回転">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="20" Height="20" Margin="0,0,4,0">
                        <Canvas Width="20" Height="20">
                            <!-- 反時計回りの曲線矢印 -->
                            <Path Data="M 18,10 Q 10,18 2,10" 
                                  Stroke="Black" 
                                  StrokeThickness="2.5" 
                                  StrokeStartLineCap="Round" 
                                  StrokeEndLineCap="Round"/>
                            <!-- 矢印の先端 -->
                            <Path Data="M 5,13 L 2,10 L 5,7" 
                                  Stroke="Black" 
                                  StrokeThickness="2.5" 
                                  StrokeStartLineCap="Round" 
                                  StrokeEndLineCap="Round" 
                                  StrokeLineJoin="Round" 
                                  Fill="Black"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="90° 左回転" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Content="🖼️ サムネイル" Command="{Binding ToggleViewCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="サムネイル/リスト表示切替"/>
            <Button Content="👁️ プレビュー" Command="{Binding TogglePreviewCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="プレビュー表示ON/OFF"/>
            <Separator/>
            <TextBlock Text="💡 F2キーでファイル名変更" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray" FontSize="11"/>
        </ToolBar>

        <!-- メインコンテンツエリア（3ペイン構成） -->
        <Grid Grid.Row="2" x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="ThumbnailColumn" Width="400" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="PreviewColumn" Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- 左ペイン: フォルダツリー -->
            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5" ToolTip="PDFをドラッグ&amp;ドロップでフォルダにコピー">
                <TreeView x:Name="FolderTreeView"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          ContextMenuOpening="FolderTreeView_ContextMenuOpening">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="AllowDrop" Value="True"/>
                            <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded"/>
                            <EventSetter Event="PreviewDragOver" Handler="FolderTreeViewItem_DragOver"/>
                            <EventSetter Event="PreviewDrop" Handler="FolderTreeViewItem_Drop"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁 " FontSize="14"/>
                                <TextBlock Text="{Binding Name}" FontSize="12"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                    <TreeView.ContextMenu>
                        <ContextMenu x:Name="FolderContextMenu">
                            <MenuItem Header="お気に入りに追加" 
                                      x:Name="AddFavoriteMenuItem"
                                      Click="AddFavoriteMenuItem_Click"/>
                            <MenuItem Header="お気に入りから削除" 
                                      x:Name="RemoveFavoriteMenuItem"
                                      Click="RemoveFavoriteMenuItem_Click"/>
                            <MenuItem Header="お気に入りの名前を変更" 
                                      x:Name="RenameFavoriteMenuItem"
                                      Click="RenameFavoriteMenuItem_Click"/>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <!-- 中央ペイン: サムネイル/リスト -->
            <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5,5,0,5">
                <Grid>
                    <!-- サムネイルビュー -->
                    <ListView x:Name="ThumbnailListView"
                              ItemsSource="{Binding PdfFiles}" 
                              SelectedItem="{Binding SelectedPdfFile}"
                              SelectionMode="Extended"
                              KeyDown="FileListView_KeyDown"
                              MouseDoubleClick="ThumbnailItem_DoubleClick"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsThumbnailView, Converter={StaticResource BoolToVisibilityConverter}}"
                              ContextMenuOpening="FileListView_ContextMenuOpening">
                        <ListView.ContextMenu>
                            <ContextMenu x:Name="FileContextMenu">
                                <MenuItem Header="右に90度回転（時計回り）" 
                                          x:Name="RotateRightMenuItem"
                                          Click="RotateRightMenuItem_Click"/>
                                <MenuItem Header="左に90度回転（反時計回り）" 
                                          x:Name="RotateLeftMenuItem"
                                          Click="RotateLeftMenuItem_Click"/>
                                <MenuItem Header="180度回転" 
                                          x:Name="Rotate180MenuItem"
                                          Click="Rotate180MenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="コピー" Click="CopyFiles_Click" InputGestureText="Ctrl+C"/>
                                <MenuItem Header="ペースト" Click="PasteFiles_Click" InputGestureText="Ctrl+V"/>
                                <Separator/>
                                <MenuItem Header="削除" Click="DeleteFiles_Click" InputGestureText="Delete"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="{Binding DataContext.ThumbnailWidth, RelativeSource={RelativeSource AncestorType=ListView}}" 
                                            Margin="5">
                                    <Border BorderBrush="#CCCCCC" BorderThickness="1" 
                                            Height="{Binding DataContext.ThumbnailHeight, RelativeSource={RelativeSource AncestorType=ListView}}" 
                                            Background="White"
                                            MouseLeftButtonDown="ThumbnailItem_MouseLeftButtonDown"
                                            MouseLeftButtonUp="ThumbnailItem_MouseLeftButtonUp"
                                            MouseRightButtonDown="ThumbnailItem_MouseRightButtonDown"
                                            MouseRightButtonUp="ThumbnailItem_MouseRightButtonUp"
                                            MouseMove="ThumbnailItem_MouseMove"
                                            ToolTip="左ドラッグ: プレビューに挿入／フォルダにコピー | 右ドラッグ: フォルダでコピー/移動を選択">
                                        <Grid>
                                            <Image Source="{Binding ThumbnailData, Converter={StaticResource ByteArrayToImageConverter}}" 
                                                   Stretch="Uniform"/>
                                            
                                            <!-- ページめくりボタン（複数ページの場合のみ表示） -->
                                            <Grid Visibility="{Binding PageCount, Converter={StaticResource PageCountToVisibilityConverter}}"
                                                  VerticalAlignment="Bottom"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- 前のページボタン -->
                                                <Button Grid.Column="0"
                                                        Content="◀"
                                                        Width="25"
                                                        Height="25"
                                                        FontSize="12"
                                                        Padding="0"
                                                        Margin="0,0,5,0"
                                                        Click="ThumbnailPreviousPage_Click"
                                                        Tag="{Binding}"
                                                        ToolTip="前のページ"/>
                                                
                                                <!-- ページ番号表示 -->
                                                <TextBlock Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Margin="5,0"
                                                           Foreground="White"
                                                           Background="#CC000000"
                                                           Padding="5,2"
                                                           TextAlignment="Center"
                                                           MinWidth="40">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}/{1}">
                                                            <Binding Path="DisplayPageNumber"/>
                                                            <Binding Path="PageCount"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                
                                                <!-- 次のページボタン -->
                                                <Button Grid.Column="2"
                                                        Content="▶"
                                                        Width="25"
                                                        Height="25"
                                                        FontSize="12"
                                                        Padding="0"
                                                        Margin="5,0,0,0"
                                                        Click="ThumbnailNextPage_Click"
                                                        Tag="{Binding}"
                                                        ToolTip="次のページ"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- ファイル名（編集可能） -->
                                    <Grid Margin="0,5,0,0">
                                        <!-- 通常表示 -->
                                        <TextBlock Text="{Binding FileName}" 
                                                   TextWrapping="Wrap" 
                                                   FontSize="12" 
                                                   HorizontalAlignment="Center"
                                                   Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                        
                                        <!-- 編集モード -->
                                        <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12"
                                                 HorizontalAlignment="Stretch"
                                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 LostFocus="FileNameEdit_LostFocus"
                                                 KeyDown="FileNameEdit_KeyDown"
                                                 Loaded="FileNameEdit_Loaded"/>
                                    </Grid>
                                    
                                    <TextBlock Text="{Binding FormattedFileSize}" 
                                               FontSize="11" 
                                               Foreground="Gray"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- リストビュー -->
                    <ListView x:Name="FileListView"
                              ItemsSource="{Binding PdfFiles}"
                              SelectedItem="{Binding SelectedPdfFile}"
                              SelectionMode="Extended"
                              KeyDown="FileListView_KeyDown"
                              Visibility="{Binding IsThumbnailView, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                              ContextMenuOpening="FileListView_ContextMenuOpening">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="FileListItem_PreviewMouseLeftButtonDown"/>
                                <EventSetter Event="PreviewMouseLeftButtonUp" Handler="FileListItem_PreviewMouseLeftButtonUp"/>
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="FileListItem_PreviewMouseRightButtonDown"/>
                                <EventSetter Event="PreviewMouseRightButtonUp" Handler="FileListItem_PreviewMouseRightButtonUp"/>
                                <EventSetter Event="PreviewMouseMove" Handler="FileListItem_PreviewMouseMove"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ContextMenu>
                            <ContextMenu x:Name="FileListContextMenu">
                                <MenuItem Header="右に90度回転（時計回り）" 
                                          x:Name="RotateRightListMenuItem"
                                          Click="RotateRightMenuItem_Click"/>
                                <MenuItem Header="左に90度回転（反時計回り）" 
                                          x:Name="RotateLeftListMenuItem"
                                          Click="RotateLeftMenuItem_Click"/>
                                <MenuItem Header="180度回転" 
                                          x:Name="Rotate180ListMenuItem"
                                          Click="Rotate180MenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="コピー" Click="CopyFiles_Click" InputGestureText="Ctrl+C"/>
                                <MenuItem Header="ペースト" Click="PasteFiles_Click" InputGestureText="Ctrl+V"/>
                                <Separator/>
                                <MenuItem Header="削除" Click="DeleteFiles_Click" InputGestureText="Delete"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ファイル名" Width="250">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <!-- 通常表示 -->
                                                <TextBlock Text="{Binding FileName}" 
                                                           Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                           MouseLeftButtonDown="FileName_DoubleClick"/>
                                                
                                                <!-- 編集モード -->
                                                <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                                         LostFocus="FileNameEdit_LostFocus"
                                                         KeyDown="FileNameEdit_KeyDown"
                                                         Loaded="FileNameEdit_Loaded"/>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="サイズ" Width="100" DisplayMemberBinding="{Binding FormattedFileSize}"/>
                                <GridViewColumn Header="更新日時" Width="150" DisplayMemberBinding="{Binding LastModified, StringFormat=yyyy/MM/dd HH:mm}"/>
                                <GridViewColumn Header="ページ数" Width="80" DisplayMemberBinding="{Binding PageCount}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"
                          Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- 右ペイン: プレビュー -->
            <Border Grid.Column="4" 
                    BorderBrush="#CCCCCC" 
                    BorderThickness="1" 
                    Margin="0,5,5,5"
                    Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- プレビューツールバー -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#F0F0F0" Height="35">
                        <Button Content="🔍-" Margin="5" Padding="5" Command="{Binding ZoomOutCommand}"/>
                        <TextBlock Text="{Binding ZoomPercent, StringFormat={}{0}%}" VerticalAlignment="Center" Margin="5" MinWidth="40"/>
                        <Button Content="🔍+" Margin="5" Padding="5" Command="{Binding ZoomInCommand}"/>
                        <Separator/>
                        <Button Content="◀️" Margin="5" Padding="5" Command="{Binding PreviousPageCommand}"/>
                        <TextBlock VerticalAlignment="Center" Margin="5" MinWidth="50">
                            <Run Text="{Binding CurrentPageNumber}"/><Run Text="/"/><Run Text="{Binding TotalPages}"/>
                        </TextBlock>
                        <Button Content="▶️" Margin="5" Padding="5" Command="{Binding NextPageCommand}"/>
                        <Separator/>
                        <Button Content="🗑️ このページを削除" Margin="5" Padding="5" Command="{Binding DeleteCurrentPageCommand}" ToolTip="表示中のページを削除"/>
                        <TextBlock Text="💡 PDFをドロップで挿入" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray" FontSize="11"/>
                    </StackPanel>

                    <!-- プレビュー表示エリア（PDFをドロップで挿入） -->
                    <Border Grid.Row="1" Background="White" x:Name="PreviewDropTarget"
                            AllowDrop="True" DragOver="Preview_DragOver" Drop="Preview_Drop">
                        <ScrollViewer x:Name="PreviewScrollViewer" 
                                      HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Auto">
                            <Image x:Name="PreviewImage" 
                                   Source="{Binding PreviewImageData, Converter={StaticResource ByteArrayToImageConverter}}"
                                   Stretch="None"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ステータスバー -->
        <StatusBar Grid.Row="3" Height="25" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding PdfFiles.Count, StringFormat='{}{0}項目'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding IsPreviewVisible, StringFormat='プレビュー: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding TrialStatusText}" 
                          Foreground="{Binding IsTrialExpiringSoon, Converter={StaticResource BoolToColorConverter}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
