<Window x:Class="PdfHandler.UI.Views.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDFハンドラ"
        Width="400" Height="240"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True">
    <Border CornerRadius="12"
            Background="#FF2D2D2D"
            BorderBrush="#FF444444"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- アイコン＋タイトル -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <Image Source="/Assets/PdfHandler.ico" Width="56" Height="56"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="PDFハンドラ"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="VersionText"
                           FontSize="12" Foreground="#FFAAAAAA"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ステータステキスト -->
            <TextBlock x:Name="StatusText"
                       Grid.Row="1"
                       Text="初期化中..."
                       FontSize="12" Foreground="#FFCCCCCC"
                       HorizontalAlignment="Center"
                       Margin="20,0,20,8"/>

            <!-- プログレスバー -->
            <Grid Grid.Row="2" VerticalAlignment="Center" Margin="30,0,30,20">
                <ProgressBar x:Name="SplashProgressBar"
                             IsIndeterminate="True"
                             Height="6"
                             Background="#FF444444"
                             Foreground="#FF4A90D9"
                             BorderThickness="0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
