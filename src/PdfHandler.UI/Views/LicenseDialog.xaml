<Window x:Class="PdfHandler.UI.Views.LicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ライセンス"
        Height="550"
        Width="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 現在のライセンス状態 -->
        <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="1" Background="White"
                Padding="15" Margin="0,0,0,15" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="ライセンス" FontSize="20" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,10"/>
                <TextBlock x:Name="LicensePlanText" Text="読み込み中..." FontWeight="SemiBold" FontSize="14" Foreground="#333333"/>
                <TextBlock x:Name="LicenseStatusText" Text="" Foreground="#555555" FontSize="13" Margin="0,3,0,0"/>
                <TextBlock x:Name="TrialDaysText" Text="" Foreground="#0066CC" FontSize="12" Margin="0,3,0,0" Visibility="Collapsed"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="DeviceManagerButton" Content="⚙ デバイス管理" Click="DeviceManagerButton_Click"
                            Padding="12,8" Margin="0,0,10,0" Background="#6C757D" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 購入・ライセンスキー入力 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="購入・ライセンスキー" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#333333"/>
                <TextBlock x:Name="HeaderMessageText" Text="ライセンスを購入して全機能をご利用ください。" FontSize="13" Foreground="#555555" Margin="0,0,0,15"/>

                <!-- Standard買い切り -->
                <Border x:Name="StandardPurchasedBorder" BorderBrush="#CCCCCC" BorderThickness="1"
                        Background="White" Margin="0,0,0,12" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Standard版（買い切り）" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="¥4,980（消費税不課税）" FontSize="28" Foreground="#0066CC" Margin="0,0,0,8"/>
                        <TextBlock Text="• PDF結合・分割・専用ワークフォルダ・永続利用" FontSize="12" Foreground="#555555"/>
                        <StackPanel x:Name="PurchasedStatePanel" Margin="0,12,0,0" Visibility="Collapsed">
                            <Border Background="#E8F5E9" Padding="10" CornerRadius="5" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="✓ ご購入済みです" FontSize="13" Foreground="#2E7D32" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ValidVersionRangeText" Text="" FontSize="11" Foreground="#388E3C" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                            <CheckBox x:Name="AdditionalPurchaseCheckBox" Content="追加購入する（確認の上チェック）"
                                      FontSize="12" Foreground="#555555" Margin="0,0,0,8"
                                      Checked="AdditionalPurchaseCheckBox_Changed" Unchecked="AdditionalPurchaseCheckBox_Changed"/>
                            <Button x:Name="PurchaseStandardButton" Content="追加購入する" Padding="15,6"
                                    Click="PurchaseStandardLifetime_Click" Background="#0066CC" Foreground="White"
                                    BorderThickness="0" IsEnabled="False"/>
                        </StackPanel>
                        <StackPanel x:Name="NotPurchasedStatePanel" Margin="0,12,0,0">
                            <Button x:Name="PurchaseStandardButtonFirst" Content="購入する" Padding="15,6"
                                    Click="PurchaseStandardLifetime_Click" Background="#0066CC" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- まとめ買い・請求書払い（法人直接営業中は非表示） -->
                <Border x:Name="VolumeLicenseBorder" BorderBrush="#6C757D" BorderThickness="1"
                        Background="White" Margin="0,0,0,12" Padding="15" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="まとめ買い・請求書払い" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="複数台のライセンスや請求書払いをご希望の場合は、サポートまでお問い合わせください。" 
                                   FontSize="13" Foreground="#555555" Margin="0,0,0,8"/>
                        <TextBlock Text="• 見積・請求書払いに対応" FontSize="12" Margin="0,2"/>
                        <TextBlock Text="• ライセンスキーを各PCに配布してアクティベーション" FontSize="12" Margin="0,2"/>
                        <Button x:Name="VolumeLicenseContactButton" Content="サポートへ問い合わせる" Click="VolumeLicenseContact_Click"
                                Margin="0,12,0,0" Padding="15,6" Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <Separator Margin="0,15,0,15" Background="#DDDDDD"/>

                <!-- 利用規約・プライバシー -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Content="📄 利用規約" Click="TermsOfUse_Click" Margin="0,0,10,0" Padding="10,6" Background="White" BorderBrush="#CCCCCC" Cursor="Hand"/>
                    <Button Content="🔒 プライバシーポリシー" Click="PrivacyPolicy_Click" Padding="10,6" Background="White" BorderBrush="#CCCCCC" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- フッター -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="ライセンスキーを入力" Width="140" Margin="0,0,10,0" Click="EnterLicenseKey_Click"/>
            <Button Content="閉じる" Width="80" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
