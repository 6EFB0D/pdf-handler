<Window x:Class="PdfHandler.UI.Views.PurchaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ライセンス購入" 
        Height="480" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="PDFハンドラ ライセンス購入" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>
            <TextBlock x:Name="HeaderMessageText"
                       Text="ライセンスを購入して全機能をご利用ください。" 
                       FontSize="14"
                       Foreground="#666666"/>
        </StackPanel>

        <!-- プラン選択 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Standard買い切り -->
                <Border x:Name="StandardPurchasedBorder" BorderBrush="#CCCCCC" BorderThickness="1" 
                        Background="White" Margin="0,0,0,15" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Standard版（買い切り）" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="¥4,980（税込）" FontSize="32" Foreground="#0066CC" Margin="0,0,0,10"/>
                        <TextBlock Text="• PDF結合・分割（無制限）" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="• ページ回転・ファイル名変更" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="• 専用ワークフォルダ" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="• 永続利用" FontSize="13" Margin="0,3"/>
                        <!-- 購入済み表示 -->
                        <StackPanel x:Name="PurchasedStatePanel" Margin="0,15,0,0" Visibility="Collapsed">
                            <Border Background="#E8F5E9" Padding="12" CornerRadius="5" Margin="0,0,0,10">
                                <TextBlock x:Name="PurchasedLabelText" Text="✓ このライセンスはご購入済みです" 
                                           FontSize="14" Foreground="#2E7D32" FontWeight="SemiBold"/>
                            </Border>
                            <CheckBox x:Name="AdditionalPurchaseCheckBox" 
                                      Content="追加でライセンスを購入する（上記をご確認の上チェック）"
                                      FontSize="12" Foreground="#555555" Margin="0,0,0,10"
                                      Checked="AdditionalPurchaseCheckBox_Changed" Unchecked="AdditionalPurchaseCheckBox_Changed"/>
                            <Button x:Name="PurchaseStandardButton" Content="追加購入する" Padding="20,8"
                                    Click="PurchaseStandardLifetime_Click"
                                    Background="#0066CC" Foreground="White" BorderThickness="0"
                                    IsEnabled="False"/>
                        </StackPanel>
                        <!-- 未購入時 -->
                        <StackPanel x:Name="NotPurchasedStatePanel" Margin="0,15,0,0">
                            <Button x:Name="PurchaseStandardButtonFirst" Content="購入する" Padding="20,8"
                                    Click="PurchaseStandardLifetime_Click"
                                    Background="#0066CC" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- お纏め買い（ボリュームライセンス）（法人直接営業中は非表示） -->
                <Border x:Name="VolumeLicenseBorder"
                        BorderBrush="#6C757D" BorderThickness="1"
                        Background="White" Margin="0,0,0,15" Padding="20" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="お纏め買いをご希望の方" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="複数台分のライセンスが必要な場合は、サポートまでお問い合わせください。" FontSize="14" Foreground="#555555" Margin="0,0,0,10"/>
                        <TextBlock Text="• 見積・請求書払いに対応" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="• ライセンスキーを各PCに配布してアクティベーション" FontSize="13" Margin="0,3"/>
                        <Button x:Name="VolumeLicenseContactButton"
                                Content="サポートへ問い合わせる"
                                Click="VolumeLicenseContact_Click"
                                Margin="0,15,0,0" Padding="20,8"
                                Background="#6C757D" Foreground="White" BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- フッター -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="後で" Width="100" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="ライセンスキーを入力" Width="150"
                    Click="EnterLicenseKey_Click"/>
        </StackPanel>
    </Grid>
</Window>




