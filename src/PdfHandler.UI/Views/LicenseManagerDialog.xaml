<Window x:Class="PdfHandler.UI.Views.LicenseManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ライセンス管理"
        Height="500"
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0"
                   Text="登録デバイス管理"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#333333"/>

        <!-- ライセンス番号 -->
        <Border x:Name="LicenseKeyBorder" Grid.Row="2"
                BorderBrush="#CCCCCC" BorderThickness="1"
                Background="White" CornerRadius="5" Padding="12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ライセンス番号: " FontSize="13" Foreground="#555555" VerticalAlignment="Center"/>
                <TextBlock x:Name="LicenseKeyText" Text="" FontSize="13" FontFamily="Consolas" Foreground="#333333"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button x:Name="CopyLicenseKeyButton" Content="コピー" Width="70" Height="26" FontSize="12"
                        Click="CopyLicenseKey_Click"/>
            </StackPanel>
        </Border>

        <!-- 登録数 -->
        <TextBlock x:Name="DeviceCountText"
                   Grid.Row="4"
                   Text="登録デバイス: 読み込み中..."
                   FontSize="14"
                   Foreground="#555555"/>

        <!-- デバイス一覧 -->
        <Border Grid.Row="6"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                Background="White"
                CornerRadius="5"
                Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DeviceListPanel"/>
            </ScrollViewer>
        </Border>

        <!-- 説明とボタン -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="更新"
                    Width="80"
                    Height="32"
                    Margin="0,0,10,0"
                    FontSize="13"
                    Click="RefreshButton_Click"/>
            <Button Content="閉じる"
                    Width="80"
                    Height="32"
                    FontSize="13"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
