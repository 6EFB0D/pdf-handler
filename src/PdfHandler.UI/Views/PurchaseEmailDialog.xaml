<Window x:Class="PdfHandler.UI.Views.PurchaseEmailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="購入メールアドレスの確認"
        Width="480"
        SizeToContent="Height"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,14" FontSize="13" Foreground="#333333"
                   Text="ライセンスキーと領収の案内を、このメールアドレスに送信します。&#x0a;誤入力に注意し、同じ内容を2回入力してください。"/>

        <TextBlock Grid.Row="1" Text="メールアドレス" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="EmailTextBox" Grid.Row="2" Padding="8,6" FontSize="14"
                 Margin="0,0,0,12"/>

        <TextBlock Grid.Row="3" Text="確認（もう一度）" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="ConfirmEmailTextBox" Grid.Row="4" Padding="8,6" FontSize="14" MinHeight="40"
                 Margin="0,0,0,4"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="キャンセル" Width="100" Margin="0,0,10,0" IsCancel="True"/>
            <Button Content="決済に進む" Width="110" IsDefault="True" Click="Ok_Click"
                    Background="#0066CC" Foreground="White" BorderThickness="0" Padding="12,8"/>
        </StackPanel>
    </Grid>
</Window>
