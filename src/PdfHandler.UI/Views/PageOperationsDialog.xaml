<Window x:Class="PdfHandler.UI.Views.PageOperationsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ページの削除・挿入"
        Width="520"
        Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 対象ファイル -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="対象ファイル:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock x:Name="TargetFileText" TextWrapping="Wrap"/>
            <TextBlock x:Name="PageCountText" Margin="0,5,0,0" Foreground="Gray"/>
        </StackPanel>

        <!-- 操作選択 -->
        <TextBlock Grid.Row="1" Text="操作:" FontWeight="Bold" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
            <StackPanel>
                <Border BorderBrush="#CCCCCC" BorderThickness="1" Background="White" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <RadioButton x:Name="DeleteRadio" Content="ページを削除" IsChecked="True" Margin="0,0,0,15" Checked="OperationMode_Changed"/>
                        <StackPanel x:Name="DeletePanel">
                            <TextBlock Text="削除するページ:" Margin="0,0,0,5"/>
                            <TextBox x:Name="DeletePagesTextBox" Padding="5" Margin="0,0,0,5"/>
                            <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap"
                                       Text="例: 1, 3, 5-7 (カンマ区切り。範囲は 5-7 のように指定)"/>
                        </StackPanel>

                        <RadioButton x:Name="InsertRadio" Content="ページを挿入" Margin="0,20,0,15" Checked="OperationMode_Changed"/>
                        <StackPanel x:Name="InsertPanel" IsEnabled="False">
                            <TextBlock Text="挿入位置:" Margin="0,0,0,5"/>
                            <TextBox x:Name="InsertPositionTextBox" Width="80" Padding="5" Margin="0,0,0,15" PreviewTextInput="NumberOnly_PreviewTextInput"/>
                            <TextBlock Text="挿入元PDF:" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InsertSourcePathTextBox" IsReadOnly="True" Padding="5" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="参照..." Width="80" Height="30" Margin="10,0,0,0" Click="BrowseInsertSource_Click"/>
                            </Grid>
                            <TextBlock Text="挿入元のページ番号:" Margin="0,0,0,5"/>
                            <TextBox x:Name="InsertSourcePageTextBox" Width="80" Padding="5" PreviewTextInput="NumberOnly_PreviewTextInput"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 出力先 -->
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="出力先:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <RadioButton x:Name="OverwriteRadio" Content="元のファイルを上書き" IsChecked="True" Margin="0,0,0,5" Checked="OutputMode_Changed"/>
                    <RadioButton x:Name="NewFileRadio" Content="別ファイルに保存" Margin="0,0,0,5" Checked="OutputMode_Changed"/>
                    <Grid x:Name="OutputPathGrid" Margin="25,0,0,0" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OutputPathTextBox" IsReadOnly="True" Padding="5" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="参照..." Width="80" Height="30" Margin="10,0,0,0" Click="BrowseOutput_Click"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 実行ボタン -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="ExecuteButton" Content="実行" Width="100" Height="35" Margin="0,0,10,0"
                    IsDefault="True" Click="ExecuteButton_Click" FontWeight="Bold"/>
            <Button Content="キャンセル" Width="100" Height="35" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
