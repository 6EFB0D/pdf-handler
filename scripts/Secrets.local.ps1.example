# Local secrets for PDF Handler scripts (DO NOT COMMIT).
# 1) Copy this file as: scripts\Secrets.local.ps1
# 2) Replace placeholders with real values.
# 3) scripts\Secrets.local.ps1 is ignored by .gitignore.

# PROD Supabase anon key used by build-release.ps1 / run-prod.ps1
$env:PDFHANDLER_PROD_SUPABASE_ANON_KEY = "sb_publishable_replace_with_prod_key"

# Optional shared URLs used by build-release.ps1
# $env:CONTACT_URL = "https://example.com/contact"
# $env:PRODUCT_PAGE_URL = "https://example.com/product"
# $env:SURVEY_FORM_URL = "https://example.com/survey"
